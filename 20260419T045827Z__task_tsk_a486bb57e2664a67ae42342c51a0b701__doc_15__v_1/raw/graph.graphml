ata></node><node id="ent_2de1ff7fab24ff66"><data key="name">压力大幅波动</data><data key="type">故障损伤</data></node><node id="ent_9fef5a1a061c4830"><data key="name">新港</data><data key="type">地点</data></node><node id="ent_80bac3c1d403e6be"><data key="name">营口</data><data key="type">地点</data></node><node id="ent_71444caeffb2b5ea"><data key="name">备用活塞</data><data key="type">设备部件</data></node><node id="ent_926ca639b6813026"><data key="name">令槽内台阶</data><data key="type">设备部件</data></node><node id="ent_1d841a64292ec069"><data key="name">第 2 缸缸套</data><data key="type">设备部件</data></node><node id="ent_556392fb2ddc0320"><data key="name">第 7 缸缸套</data><data key="type">设备部件</data></node><node id="ent_b8becfd62a177f0a"><data key="name">备用缸套</data><data key="type">设备部件</data></node><node id="ent_e1fa328c04aa6c4d"><data key="name">异常磨损</data><data key="type">故障损伤</data></node><node id="ent_02f9092bcf02521f"><data key="name">将令槽内台阶锉平</data><data key="type">处置措施</data></node><node id="ent_4e5ba63bfac51235"><data key="name">换新</data><data key="type">处置措施</data></node><node id="ent_050c5f117d914bef"><data key="name">堆焊修理</data><data key="type">处置措施</data></node><node id="ent_35b6637276de592f"><data key="name">PNH 轮第 3 缸排温异常及排气凸轮移位事故</data><data key="type">事故案例</data></node><node id="ent_291d5af79cacef34"><data key="name">油嘴</data><data key="type">设备部件</data></node><node id="ent_a9c6758f89b2121c"><data key="name">排气凸轮</data><data key="type">设备部件</data></node><node id="ent_aeab73e527fbd6d8"><data key="name">第 3 缸排温显著升高</data><data key="type">故障损伤</data></node><node id="ent_ddb382125416f372"><data key="name">扫气箱高温报警</data><data key="type">故障损伤</data></node><node id="ent_95baa87200810cb5"><data key="name">排气阀被吹坏</data><data key="type">原因因素</data></node><node id="ent_cfe52614ae663f16"><data key="name">排气定时有问题</data><data key="type">原因因素</data></node><node id="ent_11d51334c70f2ca0"><data key="name">排气凸轮移位约 25 度</data><data key="type">原因因素</data></node><node id="ent_c00b6fd3b2444f0e"><data key="name">单缸减油</data><data key="type">处置措施</data></node><node id="ent_070f6dd6f1c6f001"><data key="name">维持航行至锚地</data><data key="type">处置措施</data></node><node id="ent_c274f6a2fa821743"><data key="name">更换备用排气阀和 2 只油嘴</data><data key="type">处置措施</data></node><node id="ent_b2db15382a588246"><data key="name">用专用液压工具调整复位</data><data key="type">处置措施</data></node><node id="ent_fee10d79b597ea09"><data key="name">澳大利亚丹皮尔港</data><data key="type">地点</data></node><node id="ent_09f3c70fb8a70fd1"><data key="name">航道</data><data key="type">地点</data></node><node id="ent_7bcbf1d0f4dbde98"><data key="name">TH 轮主机气缸油混用造成活塞环异常磨损</data><data key="type">事故案例</data></node><node id="ent_02436c4f3cd2c89d"><data key="name">TH 轮</data><data key="type">船舶</data></node><node id="ent_6aeaf426da81f3bb"><data key="name">No.1～No.6 缸</data><data key="type">设备部件</data></node><node id="ent_415df9732ec3e3e4"><data key="name">燃油喷射系统</data><data key="type">设备部件</data></node><node id="ent_eb86887749707a84"><data key="name">扫气温度升高</data><data key="type">故障损伤</data></node><node id="ent_f68de6a99c324154"><data key="name">擅自多次更换供船气缸油品种</data><data key="type">原因因素</data></node><node id="ent_1a3740b03d10b543"><data key="name">主机气缸油混用</data><data key="type">原因因素</data></node><node id="ent_e7849a830da65c6c"><data key="name">清洁扫气箱</data><data key="type">防范要求</data></node><node id="ent_898dcccee3ada03f"><data key="name">严格按说明书要求操作排污</data><data key="type">防范要求</data></node><node id="ent_d4f676d521a05dc9"><data key="name">定时对每个缸逐一排放</data><data key="type">防范要求</data></node><node id="ent_fc4fd1edc6021f94"><data key="name">不能把几个缸排污阀同时打开</data><data key="type">防范要求</data></node><node id="ent_1a257f34485f4c83"><data key="name">确保活塞下部缓冲空间内无残油、残渣和积水</data><data key="type">防范要求</data></node><node id="ent_0e1a542a535f13bf"><data key="name">YC 轮主机缸套、活塞异常磨损</data><data key="type">事故案例</data></node><node id="ent_4dd06de56e177da4"><data key="name">YC 轮</data><data key="type">船舶</data></node><node id="ent_b434ae3055a65e14"><data key="name">第 7 缸</data><data key="type">设备部件</data></node><node id="ent_20c3f7d72454b03a"><data key="name">环槽</data><data key="type">设备部件</data></node><node id="ent_056309e9647e5144"><data key="name">扫气口</data><data key="type">设备部件</data></node><node id="ent_8a3f433a868bfdd2"><data key="name">排烟温度异常偏高</data><data key="type">故障损伤</data></node><node id="ent_3fd4e4e9f4220cc2"><data key="name">扫气箱温度异常偏高</data><data key="type">故障损伤</data></node><node id="ent_11ac77055870b10c"><data key="name">烟色不良</data><data key="type">故障损伤</data></node><node id="ent_488f20724db347be"><data key="name">缸套及活塞第一道环槽处有异常磨损</data><data key="type">故障损伤</data></node><node id="ent_b08be47e16fe0ca5"><data key="name">第 3 缸活塞环最大宽度达 22.4 mm</data><data key="type">故障损伤</data></node><node id="ent_d15d650395ff064e"><data key="name">环槽内有 3 mm 台阶</data><data key="type">故障损伤</data></node><node id="ent_8c765e91278901c5"><data key="name">第 7 缸缸套磨损严重</data><data key="type">故障损伤</data></node><node id="ent_a3dc437cb3ee92f9"><data key="name">其余缸均较脏</data><data key="type">故障损伤</data></node><node id="ent_8979c038f9429266"><data key="name">第 4、6 缸活塞第一道环槽的磨损</data><data key="type">故障损伤</data></node><node id="ent_9ea968d45f08c450"><data key="name">海况不好</data><data key="type">原因因素</data></node><node id="ent_e256f6ed820140b4"><data key="name">主机减负荷坚持航行到港</data><data key="type">处置措施</data></node><node id="ent_958908a97cbfba24"><data key="name">对第 2、3、7 缸吊缸检查</data><data key="type">处置措施</data></node><node id="ent_0de6c51c46f84833"><data key="name">通过扫气箱检查各缸扫气口</data><data key="type">处置措施</data></node><node id="ent_6ac3905187ecbb75"><data key="name">第 3 缸活塞换新</data><data key="type">处置措施</data></node><node id="ent_0c74a21a8472c0f0"><data key="name">对第 4、6 缸吊缸检查</data><data key="type">处置措施</data></node><node id="ent_9c148b024705c935"><data key="name">CH 轮</data><data key="type">船舶</data></node><node id="ent_1d8a35ef88bbb3ba"><data key="name">轴套</data><data key="type">设备部件</data></node><node id="ent_c72cc3d31011bb6f"><data key="name">衬套</data><data key="type">设备部件</data></node><node id="ent_b7a91e7e5677de3c"><data key="name">转子轴</data><data key="type">设备部件</data></node><node id="ent_95bcf40454028e53"><data key="name">外壳</data><data key="type">设备部件</data></node><node id="ent_db7a9f7ae67036ad"><data key="name">废气端轴承</data><data key="type">设备部件</data></node><node id="ent_72cf744edb6c9b65"><data key="name">推力块</data><data key="type">设备部件</data></node><node id="ent_1192ed093fe16754"><data key="name">转子衬套</data><data key="type">设备部件</data></node><node id="ent_bacc6b3e1c3beebe"><data key="name">新转子</data><data key="type">设备部件</data></node><node id="ent_778d201e51c0a7dc"><data key="name">压气端轴承又烧坏</data><data key="type">故障损伤</data></node><node id="ent_402c9398fadd50db"><data key="name">压气端叶轮下沉擦碰外壳</data><data key="type">故障损伤</data></node><node id="ent_c4e1b901e02f06cf"><data key="name">废气端轴承、推力块也烧坏</data><data key="type">故障损伤</data></node><node id="ent_a154077152563a30"><data key="name">两只转子衬套出现数道龟裂</data><data key="type">故障损伤</data></node><node id="ent_2a8136011ce88c46"><data key="name">再次咬死</data><data key="type">故障损伤</data></node><node id="ent_9ae0ac8de931de75"><data key="name">轴套备件内外径尺寸不对</data><data key="type">原因因素</data></node><node id="ent_2b84cf394f2739b3"><data key="name">临时采用加温办法将衬套红套在转子轴上</data><data key="type">处置措施</data></node><node id="ent_f706767646a929f5"><data key="name">人工修磨</data><data key="type">处置措施</data></node><node id="ent_bff0b3b82ea9039e"><data key="name">更换轴套</data><data key="type">处置措施</data></node><node id="ent_8a71b8e92a9c0af2"><data key="name">从德国购买一台新转子装复</data><data key="type">处置措施</data></node><node id="ent_5f768272d7c09e3d"><data key="name">CH 轮主机增压器轴承多次烧毁、转子损坏</data><data key="type">事故案例</data></node><node id="ent_41e21b929261815b"><data key="name">主机增压器</data><data key="type">设备部件</data></node><node id="ent_1bd9c0f4bb06faa6"><data key="name">主机各缸排烟温度明显升高</data><data key="type">故障损伤</data></node><node id="ent_40c9848858b8c19e"><data key="name">主机滑油循环油柜透气孔向外冒热气</data><data key="type">故障损伤</data></node><node id="ent_b2c568fdfa1712ba"><data key="name">主机增压器发出"呼啦、呼啦"的喘振声</data><data key="type">故障损伤</data></node><node id="ent_155726755704081e"><data key="name">压气端轴承、轴套损坏</data><data key="type">故障损伤</data></node><node id="ent_ff922d376f631df4"><data key="name">叶轮下沉与涡壳相碰</data><data key="type">故障损伤</data></node><node id="ent_279d3c6bb31ec31c"><data key="name">磨损达 4.5mm</data><data key="type">故障损伤</data></node><node id="ent_72392b98fc460122"><data key="name">降速维持航行</data><data key="type">处置措施</data></node><node id="ent_98f5b83ab0654018"><data key="name">拆检增压器</data><data key="type">处置措施</data></node><node id="ent_ed61733f90551f32"><data key="name">更换轴承</data><data key="type">处置措施</data></node><node id="ent_abc4507b113cc831"><data key="name">测量了转子跳动量和有关间隙数据</data><data key="type">处置措施</data></node><node id="ent_8306f557d3b26d55"><data key="name">澳大利亚</data><data key="type">地点</data></node><node id="ent_839967a0fdd64eef"><data key="name">船舶主机滑油，尤其是气缸油，原则上应按造机厂建议品种选用。一旦选定，不宜随便更换。确需更换时，应认真研究新油品性能指标是否可替代，并确认其与原油品是否具有相容性，需由供油公司作出承诺保证，并由公司技术部门决定。</data><data key="type">防范要求</data></node><node id="ent_926e919b52123d01"><data key="name">船舶更换主机气缸油前，应事先清洁气缸油日用油柜、清除油脚，尽量减少混油数量；在两种气缸油实际切换进机过程中，轮机人员应密切跟踪主机工况变化，消除因混油引起性能变化而埋下的隐患。</data><data key="type">防范要求</data></node><node id="ent_df8263a3f136b8d2"><data key="name">对主机扫气箱进行常规检查时，一旦发现断令，必须尽快寻找机会吊缸更换，不允许带断令长期运行，使故障进一步扩大并酿成恶性事故。</data><data key="type">防范要求</data></node><node id="ent_209296a1f91db5e5"><data key="name">XH 轮</data><data key="type">船舶</data></node><node id="ent_1bbef28fc1af1760"><data key="name">中间轴承油位玻璃管根部碰裂</data><data key="type">故障损伤</data></node><node id="ent_f975539bffec2148"><data key="name">中间轴承滑油漏失</data><data key="type">故障损伤</data></node><node id="ent_2d505d95cf0e6255"><data key="name">轴承在干磨状态下运行</data><data key="type">故障损伤</data></node><node id="ent_c006025f1a344a08"><data key="name">合金层严重烧毁</data><data key="type">故障损伤</data></node><node id="ent_273297043899a726"><data key="name">船厂工人在拆装艉轴液压考必林时不慎将中间轴承油位玻璃管根部碰裂且未能及时发现</data><data key="type">原因因素</data></node><node id="ent_fed920bbda43f4fc"><data key="name">主机动车时未发现中间轴承已经无油</data><data key="type">原因因素</data></node><node id="ent_fea71c1610437404"><data key="name">返回锚地抛锚</data><data key="type">处置措施</data></node><node id="ent_90b340601e6edee5"><data key="name">报公司要求回厂修理</data><data key="type">处置措施</data></node><node id="ent_807ae65c288fbadd"><data key="name">打开中间轴承</data><data key="type">处置措施</data></node><node id="ent_d7c75fe6586ae87b"><data key="name">转出下半块轴承</data><data key="type">处置措施</data></node><node id="ent_d0241f137328b7df"><data key="name">在厂修或航修期间对关键部件实施拆装时主管轮机人员必须在现场做好监修和验收</data><data key="type">防范要求</data></node><node id="ent_3cdf728178e29a9a"><data key="name">在结束厂修出厂时轮机长应督促各主管轮机员对所有检修过的设备进行全面检查不能遗漏</data><data key="type">防范要求</data></node><node id="ent_d29b461ceac390c9"><data key="name">中间轴承油位玻璃管</data><data key="type">设备部件</data></node><node id="ent_a64e854fcecb2d7e"><data key="name">中间轴承</data><data key="type">设备部件</data></node><node id="ent_11e67303a3a15a0f"><data key="name">艉轴液压考必林</data><data key="type">设备部件</data></node><node id="ent_d6f5ac66678abfdf"><data key="name">合金层</data><data key="type">设备部件</data></node><node id="ent_5e409b21dc31b76a"><data key="name">JH 轮 No.6 缸曲轴红套移位事故</data><data key="type">事故案例</data></node><node id="ent_e6f46ea46103efba"><data key="name">No.6 缸曲轴</data><data key="type">设备部件</data></node><node id="ent_f5e8271e33d1880c"><data key="name">红套</data><data key="type">设备部件</data></node><node id="ent_60a648ea55f5e198"><data key="name">XH 轮主机中间轴承断油烧毁</data><data key="type">事故案例</data></node><node id="ent_3eb3ef831eed1f00"><data key="name">主机中间轴承</data><data key="type">设备部件</data></node><node id="ent_7a41587040b4b4e1"><data key="name">轴承壳</data><data key="type">设备部件</data></node><node id="ent_518191a2e2283f5a"><data key="name">布油环</data><data key="type">设备部件</data></node><node id="ent_a507797ea782eacd"><data key="name">中间轴承底座</data><data key="type">设备部件</data></node><node id="ent_2e2f156e676f50f7"><data key="name">轴承油位玻璃管</data><data key="type">设备部件</data></node><node id="ent_acbeaccf2599b314"><data key="name">油位表</data><data key="type">设备部件</data></node><node id="ent_31955d9f73213bbf"><data key="name">轴承座</data><data key="type">设备部件</data></node><node id="ent_51db22f5180604f7"><data key="name">主机中间轴承高温报警</data><data key="type">故障损伤</data></node><node id="ent_d5ee6aaaac8058d8"><data key="name">轴承壳很烫手</data><data key="type">故障损伤</data></node><node id="ent_5419b2511d0681ca"><data key="name">布油环无油带起</data><data key="type">故障损伤</data></node><node id="ent_660d3d852b166cc6"><data key="name">轴承油位玻璃管根部断裂</data><data key="type">故障损伤</data></node><node id="ent_3eaedb1835cc2a54"><data key="name">轴承内滑油已漏光</data><data key="type">故障损伤</data></node><node id="ent_1e5f57d427aea600"><data key="name">轴承座有明显扭振现象</data><data key="type">故障损伤</data></node><node id="ent_660d3d852b166cc6"><data key="name">轴承油位玻璃管根部断裂</data><data key="type">原因因素</data></node><node id="ent_47e784262daa5862"><data key="name">将油位表堵死</data><data key="type">处置措施</data></node><node id="ent_4266518e9de70785"><data key="name">补进滑油</data><data key="type">处置措施</data></node><node id="ent_25d8b36601a76958"><data key="name">将主机减速为前进一</data><data key="type">处置措施</data></node><node id="ent_f8ca911bd11426b6"><data key="name">船厂</data><data key="type">地点</data></node><node id="ent_707fb10a0bce93b9"><data key="name">滚珠轴承</data><data key="type">设备部件</data></node><node id="ent_feebe7bce6f2bdc5"><data key="name">独立润滑系统</data><data key="type">设备部件</data></node><node id="ent_cb7af7c190409c00"><data key="name">滑油</data><data key="type">设备部件</data></node><node id="ent_e30277f69061e8b0"><data key="name">TZH 轮</data><data key="type">船舶</data></node><node id="ent_a46247a8162df68d"><data key="name">不锈钢焊条</data><data key="type">设备部件</data></node><node id="ent_e31a7beb34a7badc"><data key="name">手动砂轮</data><data key="type">设备部件</data></node><node id="ent_9533f51876abd391"><data key="name">叶轮擦碰涡壳</data><data key="type">故障损伤</data></node><node id="ent_d8fcf4c6f35ec465"><data key="name">破坏转子动平衡</data><data key="type">故障损伤</data></node><node id="ent_d001e33ae8f3651b"><data key="name">巨大不平衡惯性力</data><data key="type">故障损伤</data></node><node id="ent_44590ddf45136dee"><data key="name">衬套龟裂</data><data key="type">故障损伤</data></node><node id="ent_80154b09b86130a8"><data key="name">转子的损伤未能彻底消除</data><data key="type">故障损伤</data></node><node id="ent_4f1a88caee41e410"><data key="name">咬死转子</data><data key="type">故障损伤</data></node><node id="ent_f545986bee0d70c8"><data key="name">轴承超时使用而疲劳损坏</data><data key="type">故障损伤</data></node><node id="ent_ac31edae39e62bbe"><data key="name">转子进一步损坏</data><data key="type">故障损伤</data></node><node id="ent_5d18bf899dd2153a"><data key="name">轴承损坏</data><data key="type">故障损伤</data></node><node id="ent_c6b74846f3804f32"><data key="name">TZH 轮主机缸头裂纹事故</data><data key="type">事故案例</data></node><node id="ent_0c35b40db069e251"><data key="name">主机某缸缸头出现裂纹</data><data key="type">故障损伤</data></node><node id="ent_d91184542e697213"><data key="name">轴套尺寸不对</data><data key="type">原因因素</data></node><node id="ent_015aaf8494136575"><data key="name">简单地把轴套"红套"在转子轴上，再上磨床校正</data><data key="type">原因因素</data></node><node id="ent_80154b09b86130a8"><data key="name">转子的损伤未能彻底消除</data><data key="type">原因因素</data></node><node id="ent_f697d7914be17313"><data key="name">超时使用</data><data key="type">原因因素</data></node><node id="ent_d2de85bbf0b50e4a"><data key="name">性能下降</data><data key="type">原因因素</data></node><node id="ent_0378dbeb5a37d18c"><data key="name">送厂对转子进行动平衡试验</data><data key="type">处置措施</data></node><node id="ent_589afa449161f600"><data key="name">用专用工具把转子封锁住</data><data key="type">处置措施</data></node><node id="ent_049f9bdca6b782ee"><data key="name">定期更换滑油</data><data key="type">处置措施</data></node><node id="ent_27e6e3c3ca9552c9"><data key="name">停车更换缸头</data><data key="type">处置措施</data></node><node id="ent_00081508f4e60366"><data key="name">用手动砂轮打出约 20 mm 坡口</data><data key="type">处置措施</data></node><node id="ent_860dc99497a301c1"><data key="name">用不锈钢焊条补焊</data><data key="type">处置措施</data></node><node id="ent_39c334fe9531b9e3"><data key="name">留船备用</data><data key="type">处置措施</data></node><node id="ent_52e6c8b199a33f4d"><data key="name">认真做好增压器运行时间统计记录，避免轴承超时使用而疲劳损坏</data><data key="type">防范要求</data></node><node id="ent_1b9ed3cf5a5adec6"><data key="name">当增压器轴承烧毁后，如条件不允许长时间停车，也应争取时间用专用工具把转子封锁住，以免转子进一步损坏</data><data key="type">防范要求</data></node><node id="ent_78f98c66531a9c06"><data key="name">增压器轴承滑油必须保持洁净</data><data key="type">防范要求</data></node><node id="ent_acb416f673ebd739"><data key="name">对滚珠轴承及独立润滑系统的滑油应定期更换，避免因超时使用、性能下降而导致轴承损坏</data><data key="type">防范要求</data></node><node id="ent_ed1c64599a8a7808"><data key="name">TAH 轮主机链条张紧装置调节螺杆断裂事故</data><data key="type">事故案例</data></node><node id="ent_271006a292ed1e7a"><data key="name">TAH 轮</data><data key="type">船舶</data></node><node id="ent_0ab63244bee5c3bc"><data key="name">链条箱</data><data key="type">设备部件</data></node><node id="ent_c94cf98ba7f39f0b"><data key="name">链条张紧装置</data><data key="type">设备部件</data></node><node id="ent_535b778707d28e65"><data key="name">调节螺杆</data><data key="type">设备部件</data></node><node id="ent_cb438e9eadb06e7e"><data key="name">链轨</data><data key="type">设备部件</data></node><node id="ent_9fa3689d40781691"><data key="name">固定螺丝</data><data key="type">设备部件</data></node><node id="ent_a91037451dbb8970"><data key="name">减振橡皮</data><data key="type">设备部件</data></node><node id="ent_047a22c4327479a4"><data key="name">调节螺栓</data><data key="type">设备部件</data></node><node id="ent_f1365e72b11526c7"><data key="name">底轴</data><data key="type">设备部件</data></node><node id="ent_b635bd7371f80f02"><data key="name">轴颈</data><data key="type">设备部件</data></node><node id="ent_c438d9a2607450df"><data key="name">主机链条箱内出现异常响声</data><data key="type">故障损伤</data></node><node id="ent_b59fae70a5a5505f"><data key="name">链条张紧装置调节螺杆断裂</data><data key="type">故障损伤</data></node><node id="ent_ad140e7612c1f0ff"><data key="name">链轨固定螺丝全部松动</data><data key="type">故障损伤</data></node><node id="ent_f012b0ae7e8c8041"><data key="name">链轨减振橡皮全部脱落</data><data key="type">故障损伤</data></node><node id="ent_eae33c71d7e7414d"><data key="name">调节螺栓已严重弯曲</data><data key="type">故障损伤</data></node><node id="ent_af3ed11c59b14d3f"><data key="name">底轴后端轴磨成椭圆</data><data key="type">故障损伤</data></node><node id="ent_1adedefa8ff422d3"><data key="name">轴套与轴颈间隙已达 19 mm</data><data key="type">故障损伤</data></node><node id="ent_1bef641c106753ac"><data key="name">减速停车检查</data><data key="type">处置措施</data></node><node id="ent_ee2986ad706fc431"><data key="name">采取临时固定措施</data><data key="type">处置措施</data></node><node id="ent_7105eb5af8eac90a"><data key="name">减速航行回到国内</data><data key="type">处置措施</data></node><node id="ent_092b53d455ac2241"><data key="name">驾驶台操纵船舶时，必须尽量避免运转中的螺旋桨遭受外物碰击</data><data key="type">防范要求</data></node><node id="ent_3be8535564eb8805"><data key="name">若无法避免发生撞击，应尽快停止主机运转，以减轻事故后果</data><data key="type">防范要求</data></node><node id="ent_2322a66f97497d40"><data key="name">当运转中的螺旋桨遭外来物体撞击后，驾驶台应立即通报轮机长，使轮机人员尽快对主机、轴系、艉轴封等部件进行全面检查，及时发现问题并采取措施，防止更大机损事故发生</data><data key="type">防范要求</data></node><node id="ent_780cee64a923201b"><data key="name">国内</data><data key="type">地点</data></node><node id="ent_630fc61af702b201"><data key="name">湛江</data><data key="type">地点</data></node><node id="ent_d26653dde3111ea5"><data key="name">JH 轮主机第 6 缸后主轴承螺栓断裂事故</data><data key="type">事故案例</data></node><node id="ent_7e23c402be036ce2"><data key="name">主机机架</data><data key="type">设备部件</data></node><node id="ent_fba9495e0b5b1801"><data key="name">第 6 缸排温</data><data key="type">设备部件</data></node><node id="ent_e74de06ded6f39e8"><data key="name">第 6 缸油头</data><data key="type">设备部件</data></node><node id="ent_4cbef43a2e039407"><data key="name">第 6 缸后主轴承螺栓</data><data key="type">设备部件</data></node><node id="ent_bdaf4a81c448218b"><data key="name">轴承盖</data><data key="type">设备部件</data></node><node id="ent_b743f6527ec954ff"><data key="name">第 6 缸主轴颈</data><data key="type">设备部件</data></node><node id="ent_8b6d528a696a8998"><data key="name">曲轴</data><data key="type">设备部件</data></node><node id="ent_16873934a41ac7a2"><data key="name">船体振动</data><data key="type">故障损伤</data></node><node id="ent_c4425b7c1932df37"><data key="name">主机机架有明显振动</data><data key="type">故障损伤</data></node><node id="ent_3dfa263ce31137af"><data key="name">第 6 缸排温升高很快并高温报警</data><data key="type">故障损伤</data></node><node id="ent_f1748484c7b095bf"><data key="name">第 6 缸排烟温度高</data><data key="type">故障损伤</data></node><node id="ent_cbf7fbf26d80207f"><data key="name">第 6 缸后主轴承螺栓在上部断裂</data><data key="type">故障损伤</data></node><node id="ent_b6ca41087d556de5"><data key="name">轴承盖位移</data><data key="type">故障损伤</data></node><node id="ent_895ae2d02deba97c"><data key="name">新换的两根螺栓再次断裂</data><data key="type">故障损伤</data></node><node id="ent_9eac80d2a89fd6b4"><data key="name">第 6 缸主轴颈红套滑移约 5cm</data><data key="type">故障损伤</data></node><node id="ent_b4b4922a64851ca5"><data key="name">曲轴也略有弯曲</data><data key="type">故障损伤</data></node><node id="ent_ec2602db74af119f"><data key="name">船舶空载、吃水浅</data><data key="type">原因因素</data></node><node id="ent_477e47fcd1cf43d2"><data key="name">减速并减少第 6 缸油门</data><data key="type">处置措施</data></node><node id="ent_632932c316057829"><data key="name">更换了第 6 缸油头</data><data key="type">处置措施</data></node><node id="ent_802693a77a3c74bc"><data key="name">换新两根螺栓</data><data key="type">处置措施</data></node><node id="ent_dcaa6f88bce84de8"><data key="name">对主机曲轴进行抛光修正并配加厚轴承</data><data key="type">处置措施</data></node><node id="ent_c6b14c13a87aae42"><data key="name">对第 6 缸定时做适当调整</data><data key="type">处置措施</data></node><node id="ent_4b7693dd6fd7e4ab"><data key="name">浏河锚地</data><data key="type">地点</data></node><node id="ent_801084e97d68afae"><data key="name">宁波港</data><data key="type">地点</data></node><node id="ent_a6d787838d7c5ef1"><data key="name">海上</data><data key="type">地点</data></node><node id="ent_405a83eb1cbc0125"><data key="name">JYH 轮主机 No.4 缸曲柄销机损事故</data><data key="type">事故案例</data></node><node id="ent_cef6e7f1633d1701"><data key="name">JYH 轮</data><data key="type">船舶</data></node><node id="ent_81b859f8e9da391d"><data key="name">No.4 缸</data><data key="type">设备部件</data></node><node id="ent_52767c58a201435b"><data key="name">曲柄销</data><data key="type">设备部件</data></node><node id="ent_ac9135b74ed4ff31"><data key="name">曲柄销轴承</data><data key="type">设备部件</data></node><node id="ent_4969b0694faaddab"><data key="name">上下瓦</data><data key="type">设备部件</data></node><node id="ent_33e6c6b62bc5de68"><data key="name">曲柄销颈</data><data key="type">设备部件</data></node><node id="ent_328e77a02dc01d2b"><data key="name">连杆大端轴颈</data><data key="type">设备部件</data></node><node id="ent_a91e03f3c7c39d62"><data key="name">备用新轴瓦</data><data key="type">设备部件</data></node><node id="ent_6cbddc72ee59ba07"><data key="name">加厚瓦</data><data key="type">设备部件</data></node><node id="ent_1ed3e42b431f0ab1"><data key="name">底轴后端</data><data key="type">设备部件</data></node><node id="ent_0228247d5d96544b"><data key="name">第 4 缸曲柄销轴承有挤铅现象</data><data key="type">故障损伤</data></node><node id="ent_f0b850c5c984f1cb"><data key="name">上下瓦拉铅严重</data><data key="type">故障损伤</data></node><node id="ent_8bdce284571c9481"><data key="name">曲柄销颈粘铅较多</data><data key="type">故障损伤</data></node><node id="ent_3cca8c7774859d7d"><data key="name">轴颈表面形成环形拉痕</data><data key="type">故障损伤</data></node><node id="ent_8abd5e752e4afc6b"><data key="name">该缸曲柄销道门温度偏高</data><data key="type">故障损伤</data></node><node id="ent_4ddcd4a284e70281"><data key="name">滑油压力有所下降</data><data key="type">故障损伤</data></node><node id="ent_b731bf5e3a9a7c0b"><data key="name">该缸曲柄销瓦再次出现挤铅</data><data key="type">故障损伤</data></node><node id="ent_1a695c3a63940825"><data key="name">底轴后端与轴套磨损严重</data><data key="type">故障损伤</data></node><node id="ent_6530fa44e920d335"><data key="name">调节螺杆承受的弯曲应力过大而断裂</data><data key="type">故障损伤</data></node><node id="ent_4b0c2c8e5eb42020"><data key="name">该缸轴颈造成过损伤</data><data key="type">故障损伤</data></node><node id="ent_5f964d2bcaa80b60"><data key="name">船厂制造和安装质量问题</data><data key="type">原因因素</data></node><node id="ent_649dd1669d1c3728"><data key="name">该轮 No.4 缸前不久进行循环检验拆装施工时对该缸轴颈造成过损伤</data><data key="type">原因因素</data></node><node id="ent_ec499daf200aa263"><data key="name">打开轴承检查</data><data key="type">处置措施</data></node><node id="ent_888735c634a4e450"><data key="name">船上自行将销颈用帆布打磨</data><data key="type">处置措施</data></node><node id="ent_dc3027a1b66d9fd8"><data key="name">开启机油泵冲刷油路</data><data key="type">处置措施</data></node><node id="ent_583b7c24f7d13647"><data key="name">换上备用新轴瓦</data><data key="type">处置措施</data></node><node id="ent_b346f063ed2bc33a"><data key="name">压铅至间隙正常</data><data key="type">处置措施</data></node><node id="ent_77163b76972078b3"><data key="name">采取封缸措施</data><data key="type">处置措施</data></node><node id="ent_dff14adf0453cb1c"><data key="name">减速航行至南非德班港修理</data><data key="type">处置措施</data></node><node id="ent_e032cdb61372bcf5"><data key="name">对该缸连杆大端轴颈磨去 2mm</data><data key="type">处置措施</data></node><node id="ent_990fa44e1dbeebae"><data key="name">由丹麦新做加厚瓦送船装复</data><data key="type">处置措施</data></node><node id="ent_89386b9bb18934a9"><data key="name">提高工作责任心，加强对新造船的监造以及厂修期间的验收力度</data><data key="type">防范要求</data></node><node id="ent_253dd76acfea3975"><data key="name">不断强化安全意识，严格按主机说明书要求定期做好内部检查，及时发现设备缺陷，消除隐患，避免事故发生</data><data key="type">防范要求</data></node><node id="ent_06958601b6f393a6"><data key="name">南非 RICHARD BAY 港</data><data key="type">地点</data></node><node id="ent_4b52b97baa4a112e"><data key="name">南非德班港</data><data key="type">地点</data></node><node id="ent_e9db8d962395997b"><data key="name">SHH 轮燃油舱进海水，主机燃烧恶化并裂缸套</data><data key="type">事故案例</data></node><node id="ent_4c89d0cb89527f82"><data key="name">No.5 左右燃油舱</data><data key="type">设备部件</data></node><node id="ent_919f35841d2b557f"><data key="name">No.7 左右燃油舱</data><data key="type">设备部件</data></node><node id="ent_e2d7d8bf32fd5fea"><data key="name">No.5 右燃油舱</data><data key="type">设备部件</data></node><node id="ent_28eda84138a8fdc1"><data key="name">No.5 左舱</data><data key="type">设备部件</data></node><node id="ent_df9518807b58db33"><data key="name">No.7 右舱</data><data key="type">设备部件</data></node><node id="ent_021e94630e77dcc2"><data key="name">重油沉淀柜</data><data key="type">设备部件</data></node><node id="ent_24ce5d8b4fdb6c5b"><data key="name">No.6 压载水舱</data><data key="type">设备部件</data></node><node id="ent_ef216ab3b8899a91"><data key="name">燃油舱进海水</data><data key="type">故障损伤</data></node><node id="ent_4a52ccd3adbbdcbf"><data key="name">主机燃烧恶化</data><data key="type">故障损伤</data></node><node id="ent_46a5f3aa8d97e7dc"><data key="name">裂缸套</data><data key="type">故障损伤</data></node><node id="ent_7b139ed40d2e8276"><data key="name">燃油中含海水</data><data key="type">原因因素</data></node><node id="ent_a4bae4ab9efc8668"><data key="name">及时报告公司机务部门</data><data key="type">防范要求</data></node><node id="ent_69cb17f43bca3d51"><data key="name">加强对船员业务技术培训</data><data key="type">防范要求</data></node><node id="ent_f761f08d8c3ece2d"><data key="name">美国</data><data key="type">地点</data></node><node id="ent_689ad987e25978c9"><data key="name">No.5 右油舱</data><data key="type">设备部件</data></node><node id="ent_a8026fecc0336b77"><data key="name">No.6 压载舱</data><data key="type">设备部件</data></node><node id="ent_82dde4846bc397b7"><data key="name">隔板</data><data key="type">设备部件</data></node><node id="ent_d26c2a9137b72c72"><data key="name">40 cm 长的裂缝</data><data key="type">故障损伤</data></node><node id="ent_bc7f1fc14a0d7e86"><data key="name">海水漏入 No.5 右油舱</data><data key="type">故障损伤</data></node><node id="ent_20ffa8dfe07ae26b"><data key="name">No.5 左舱被海水污染</data><data key="type">故障损伤</data></node><node id="ent_8d358ff88af6df0f"><data key="name">燃油严重脏污</data><data key="type">故障损伤</data></node><node id="ent_45354576e85c81e1"><data key="name">输送泵滤器频繁堵塞</data><data key="type">故障损伤</data></node><node id="ent_e95dfe9b6b77eaff"><data key="name">分油机故障</data><data key="type">故障损伤</data></node><node id="ent_19237db1bbc8f302"><data key="name">主机长期燃用含海水且不洁净的燃油</data><data key="type">故障损伤</data></node><node id="ent_69f5bdd4afcd5ec8"><data key="name">严重后果</data><data key="type">故障损伤</data></node><node id="ent_b7601b612852d3c2"><data key="name">含海水燃油会导致燃烧工况恶化</data><data key="type">原因因素</data></node><node id="ent_cfea4771a42dcd40"><data key="name">未能充分认识含海水燃油危害</data><data key="type">原因因素</data></node><node id="ent_4bec05e21c21b5ec"><data key="name">仅简单采取沉淀和放残水措施</data><data key="type">原因因素</data></node><node id="ent_1992d035d9748351"><data key="name">两台燃油分油机长期不能正常排污</data><data key="type">原因因素</data></node><node id="ent_b6bbbe1155d4d466"><data key="name">轮机长未着手解决分油机故障</data><data key="type">原因因素</data></node><node id="ent_27fe7444f7064900"><data key="name">将燃油输送泵进口滤芯拆除</data><data key="type">原因因素</data></node><node id="ent_19237db1bbc8f302"><data key="name">主机长期燃用含海水且不洁净的燃油</data><data key="type">原因因素</data></node><node id="ent_106988dc8218837f"><data key="name">沉淀</data><data key="type">处置措施</data></node><node id="ent_22a92cf250343b95"><data key="name">放残水</data><data key="type">处置措施</data></node><node id="ent_9cb6d8997e059705"><data key="name">No.5 右油舱与其上方 No.6 压载舱之间隔板</data><data key="type">设备部件</data></node><node id="ent_ddd22486313a3fc7"><data key="name">燃油输送泵进口滤芯</data><data key="type">设备部件</data></node><node id="ent_c7a3e2515477875b"><data key="name">燃油分油机</data><data key="type">设备部件</data></node><node id="ent_a4f0724fb121ea75"><data key="name">输送泵滤器</data><data key="type">设备部件</data></node><node id="ent_5c4c9b4c2f3ac977"><data key="name">废气锅炉</data><data key="type">设备部件</data></node><node id="ent_0210d9efebdce7f2"><data key="name">烟管</data><data key="type">设备部件</data></node><node id="ent_8dce19eb7325e54b"><data key="name">网栅</data><data key="type">设备部件</data></node><node id="ent_55911e3164b3a5af"><data key="name">第 4、5 缸</data><data key="type">设备部件</data></node><node id="ent_9417366731dedd49"><data key="name">主机燃油输送