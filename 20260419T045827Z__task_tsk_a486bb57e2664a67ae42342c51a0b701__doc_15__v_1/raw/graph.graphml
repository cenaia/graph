</data><data key="type">设备部件</data></node><node id="ent_1a8063e37d9eb726"><data key="name">第 4 缸考比林</data><data key="type">设备部件</data></node><node id="ent_b2010eb00b7b47d2"><data key="name">第 1~4 缸的凸轮轴</data><data key="type">设备部件</data></node><node id="ent_5791f7871da1ff73"><data key="name">安全阀先后起跳</data><data key="type">故障损伤</data></node><node id="ent_a1d8984795ae10b8"><data key="name">示功考克不通</data><data key="type">故障损伤</data></node><node id="ent_c048c832b0f4051d"><data key="name">爆压明显高于正常值</data><data key="type">故障损伤</data></node><node id="ent_489770af18e8644b"><data key="name">第 4 缸缸头裂缝</data><data key="type">故障损伤</data></node><node id="ent_4affd9af2fc169f4"><data key="name">排气阀吹坏</data><data key="type">故障损伤</data></node><node id="ent_74260b00067f04b2"><data key="name">第 2 缸活塞头烧蚀</data><data key="type">故障损伤</data></node><node id="ent_8d77fe6030eaeac5"><data key="name">缸头起动阀损坏</data><data key="type">故障损伤</data></node><node id="ent_e1aba26455959428"><data key="name">第 5 缸缸头、缸套同时裂损</data><data key="type">故障损伤</data></node><node id="ent_709c937c9de6ddeb"><data key="name">红套向后移动了约 9 度</data><data key="type">故障损伤</data></node><node id="ent_9159e55dfe19b66a"><data key="name">1995 年 3 月主机第 1~6 缸定时曾超前调了 5 度</data><data key="type">原因因素</data></node><node id="ent_cc41a4f58249bf69"><data key="name">适当减少主机油门</data><data key="type">处置措施</data></node><node id="ent_edbd715cc746a117"><data key="name">清通示功考克</data><data key="type">处置措施</data></node><node id="ent_28bb5475738c71f1"><data key="name">将定时调回原位</data><data key="type">处置措施</data></node><node id="ent_313eba2ab1d94f80"><data key="name">漂航检查</data><data key="type">处置措施</data></node><node id="ent_4e951135254ad730"><data key="name">对主机曲拐箱内部详细检查</data><data key="type">处置措施</data></node><node id="ent_084d581f3d7c807d"><data key="name">将主机凸轮轴第 4 缸考比林拆除</data><data key="type">处置措施</data></node><node id="ent_03139763483a286e"><data key="name">把前面第 1~4 缸的凸轮轴整体向后调节 9 度后再将考比林焊牢</data><data key="type">处置措施</data></node><node id="ent_e9