"name">第 4、5、6 缸贯穿螺栓</data><data key="type">设备部件</data></node><node id="ent_90c3f87fb5d4c474"><data key="name">凸轮轴焊接部位再次断裂</data><data key="type">故障损伤</data></node><node id="ent_cfe346dbc881f489"><data key="name">疲劳损坏并断裂</data><data key="type">故障损伤</data></node><node id="ent_1c20283e6a101ada"><data key="name">交变应力和扭矩剪切应力最集中</data><data key="type">原因因素</data></node><node id="ent_6605271c6e82455b"><data key="name">第 4、5、6 缸贯穿螺栓松动</data><data key="type">原因因素</data></node><node id="ent_0ebab96bc3ba6d3c"><data key="name">机器上下部件跳动</data><data key="type">原因因素</data></node><node id="ent_bf20c4b45039300d"><data key="name">严格按说明书要求，至少每 5 年对主机贯穿螺栓做一次全面检查</data><data key="type">防范要求</data></node><node id="ent_5d1b4e92238e51ef"><data key="name">发现松动时，应按说明书规定程序收紧</data><data key="type">防范要求</data></node><node id="ent_f480860db9325d68"><data key="name">轮机员应对主管设备及重要部件运行时间做好认真统计</data><data key="type">防范要求</data></node><node id="ent_89c1c8550da3dcfe"><data key="name">避免部件超时使用</data><data key="type">防范要求</data></node><node id="ent_1e4e673cba06b695"><data key="name">注意防止主机超负荷运行</data><data key="type">防范要求</data></node><node id="ent_9977be4940fe8710"><data key="name">在恶劣海况中，应适时降低主机负荷</data><data key="type">防范要求</data></node><node id="ent_1f5d6b6a8c6831a8"><data key="name">老旧船主机尤其应引起高度重视</data><data key="type">防范要求</data></node><node id="ent_fe9cc4e1eea8c387"><data key="name">由救助拖轮直拖返回国内港口</data><data key="type">处置措施</data></node><node id="ent_af0e6b27cc7cd915"><data key="name">国内港口</data><data key="type">地点</data></node><node id="ent_82e36dd95916632d"><data key="name">忽略口琴阀性能状况不佳这一首要因素</data><data key="type">教训为</data></node><edge id="e0" source="ent_971e855d01e0bf29" target="ent_fdbabd08f5cf65cf"><data key="type">导致</data></edge><edge id="e1" source="ent_971e855d01e0bf29" target="ent_64bdee1938e5e657"><data key="type">导致</data></edge><edge id="e2" source="ent_fdbabd08f5cf65cf" target="ent_6c416b21998a17e0"><data key="type">发生部位</data></edge><edge id="e3" source="ent_64bdee1938e5e657" 