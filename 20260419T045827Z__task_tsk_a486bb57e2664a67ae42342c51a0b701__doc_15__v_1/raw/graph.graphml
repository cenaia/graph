<?xml version="1.0" encoding="UTF-8"?><graphml xmlns="http://graphml.graphdrawing.org/xmlns"><graph id="G" edgedefault="directed"><node id="ent_52b7a4d093b7bb6d"><data key="name">沉淀柜</data><data key="type">设备部件</data></node><node id="ent_abaab86246a83a02"><data key="name">分离机械</data><data key="type">设备部件</data></node><node id="ent_6a2cdabc14034108"><data key="name">日用柜</data><data key="type">设备部件</data></node><node id="ent_bd185d1b8768d6c8"><data key="name">供油系统</data><data key="type">设备部件</data></node><node id="ent_6c416b21998a17e0"><data key="name">气缸</data><data key="type">设备部件</data></node><node id="ent_cadb65e1aa56ed53"><data key="name">燃油系统</data><data key="type">设备部件</data></node><node id="ent_971e855d01e0bf29"><data key="name">铝矿粉</data><data key="type">原因因素</data></node><node id="ent_fdbabd08f5cf65cf"><data key="name">油嘴雾化不良</data><data key="type">故障损伤</data></node><node id="ent_64bdee1938e5e657"><data key="name">燃烧不良</data><data key="type">故障损伤</data></node><node id="ent_7b1e9d3ca176ecb1"><data key="name">气缸润滑破坏</data><data key="type">故障损伤</data></node><node id="ent_ec93374dfefadb97"><data key="name">活塞环</data><data key="type">设备部件</data></node><node id="ent_67654c5f4f2e5d29"><data key="name">缸套</data><data key="type">设备部件</data></node><node id="ent_d2b1f9bed6258940"><data key="name">活塞环不正常磨损</data><data key="type">故障损伤</data></node><node id="ent_dd21bad72d75b6a6"><data key="name">活塞环咬死</data><data key="type">故障损伤</data></node><node id="ent_1f53d690aec07040"><data key="name">活塞环断裂</data><data key="type">故障损伤</data></node><node id="ent_072ddfdc9f382cf2"><data key="name">燃烧恶化</data><data key="type">故障损伤</data></node><node id="ent_342986942fe518cd"><data key="name">主机压缩压力降低</data><data key="type">故障损伤</data></node><node id="ent_cb89533744b2489b"><data key="name">有的缸不能发火</data><data key="type">故障损伤</data></node><node id="ent_898231ae4b23a8b1"><data key="name">有的缸爆燃</data><data key="type">故障损伤</data></node><node id="ent_b2cf2a9497a4bd46"><data key="name">转速下降</data><data key="type">故障损伤</data></node><node id="ent_ddee8b5513d1adaf"><data key="name">转速大幅波动</data><data key="type">故障损伤</data></node><node id="ent_d18096b0a5b7b70f"><data key="name">加强对经过货舱尤其是散货舱的各透气管、测量管的检查和保养</data><data key="type">防范要求</data></node><node id="ent_dc30599d1b87cf6d"><data key="name">发现损坏必须及时修理</data><data key="type">防范要求</data></node><node id="ent_6d7c8ca6144e635b"><data key="name">严格按照船舶燃油管理各项规定做好燃油管理工作</data><data key="type">防范要求</data></node><node id="ent_12201932b9338482"><data key="name">定期对油柜、各过滤器和分油机进行解体清洁检查</data><data key="type">防范要求</data></node><node id="ent_86c812e685dcf1db"><data key="name">发现垃圾、油脚过多时要及时查明原因消除隐患</data><data key="type">防范要求</data></node><node id="ent_6d67a7b16b0e7c84"><data key="name">确保主机在恶劣海况下安全运转</data><data key="type">防范要求</data></node><node id="ent_d1f77743ebe69746"><data key="name">货舱</data><data key="type">设备部件</data></node><node id="ent_59110fe14a4f95e4"><data key="name">散货舱</data><data key="type">设备部件</data></node><node id="ent_bae4eaf22a63d275"><data key="name">透气管</data><data key="type">设备部件</data></node><node id="ent_36d67d711d9c31d2"><data key="name">测量管</data><data key="type">设备部件</data></node><node id="ent_e709f42e5375240d"><data key="name">油柜</data><data key="type">设备部件</data></node><node id="ent_b1718bd449d116e2"><data key="name">过滤器</data><data key="type">设备部件</data></node><node id="ent_54c6b65d166f85f9"><data key="name">分油机</data><data key="type">设备部件</data></node><node id="ent_c36804f0e8a37b9b"><data key="name">主机</data><data key="type">设备部件</data></node><node id="ent_af21c79f23b00709"><data key="name">AQH 轮主机平衡器链条断损事故</data><data key="type">事故案例</data></node><node id="ent_18058b3a177ff7f8"><data key="name">AQH 轮</data><data key="type">船舶</data></node><node id="ent_e457b006c92915d2"><data key="name">主机平衡器</data><data key="type">设备部件</data></node><node id="ent_8201dacc822abf13"><data key="name">链条</data><data key="type">设备部件</data></node><node id="ent_0af691989e3fe650"><data key="name">连接板</data><data key="type">设备部件</data></node><node id="ent_64cddfbd107d9cf7"><data key="name">轴系</data><data key="type">设备部件</data></node><node id="ent_7f8a389dbf8b1f4e"><data key="name">传动链条</data><data key="type">设备部件</data></node><node id="ent_2afb5f147427c575"><data key="name">主机平衡器响声很大</data><data key="type">故障损伤</data></node><node id="ent_8bef30a29a95c520"><data key="name">主机有剧烈振动</data><data key="type">故障损伤</data></node><node id="ent_a9957b321cfa210b"><data key="name">平衡器链条已断 7 节</data><data key="type">故障损伤</data></node><node id="ent_c5a663e37aa85392"><data key="name">连接板已松动</data><data key="type">故障损伤</data></node><node id="ent_cad446d2dbd7f32f"><data key="name">传动链条损坏</data><data key="type">故障损伤</data></node><node id="ent_ab2b1ab99d09c1f1"><data key="name">连接板松动未换新且未用专用工具装配</data><data key="type">原因因素</data></node><node id="ent_d1d9469c8ab570d2"><data key="name">恶劣海况产生轴系不正常振动使主机平衡器受力大大增加</data><data key="type">原因因素</data></node><node id="ent_55ffcba212f7cec6"><data key="name">停车</data><data key="type">处置措施</data></node><node id="ent_9c2f13935e78d6ec"><data key="name">减速航行</data><data key="type">处置措施</data></node><node id="ent_1a708332f131c242"><data key="name">更换链条</data><data key="type">处置措施</data></node><node id="ent_02c28aa2680bd462"><data key="name">主机事故</data><data key="type">事故类别</data></node><node id="ent_5ae3811dac6b8fc4"><data key="name">太平洋</data><data key="type">地点</data></node><node id="ent_a1473460fd2114bd"><data key="name">香港</data><data key="type">地点</data></node><node id="ent_c9d22de9e371f946"><data key="name">六甲漂航自修中轴承更换事故</data><data key="type">事故案例</data></node><node id="ent_10c43f0a50063fac"><data key="name">旧轴承</data><data key="type">设备部件</data></node><node id="ent_c422e77e654aae30"><data key="name">新轴承</data><data key="type">设备部件</data></node><node id="ent_ee950eac6db27a55"><data key="name">透平油泵供油不正常</data><data key="type">故障损伤</data></node><node id="ent_0ec1c61bb7bbace4"><data key="name">业务水平低，工作粗心，不能在第一时间发现事故苗头</data><data key="type">原因因素</data></node><node id="ent_d76e83bad8064f10"><data key="name">未加强观察检查</data><data key="type">原因因素</data></node><node id="ent_4533b0a4549fee4f"><data key="name">不能提供准确型号和备件号</data><data key="type">原因因素</data></node><node id="ent_4cc66c0e30385747"><data key="name">未能查验出新转子的叶轮尺寸明显不一样</data><data key="type">原因因素</data></node><node id="ent_af916cf707c2e8f3"><data key="name">同意厂方安装</data><data key="type">原因因素</data></node><node id="ent_97be9b5d2b9f4dbd"><data key="name">再次停航</data><data key="type">故障损伤</data></node><node id="ent_2fb0bb7c48d3f2a0"><data key="name">机务主管应在努力提高自身业务素质的前提下，加强对船舶的现场检查与监督力度</data><data key="type">防范要求</data></node><node id="ent_3ec9b78d1d9b96c4"><data key="name">对所管船舶的技术资料、重要设备的技术状况以及船存备件情况，要有深入了解</data><data key="type">防范要求</data></node><node id="ent_45a01ad26bfdaf43"><data key="name">努力提高船员素质，加强业务技术培训和考核</data><data key="type">防范要求</data></node><node id="ent_dbbdc997b563606b"><data key="name">轮机员必须认真阅读主管设备说明书</data><data key="type">防范要求</data></node><node id="ent_e8d0f2744d9940be"><data key="name">对存放在船上的旧备件，应使用专门标签注明其名称、型号、备件号、技术性能状况、被换下时间及处理意见</data><data key="type">防范要求</data></node><node id="ent_214c8c0919de2df7"><data key="name">ZH 轮主机 No.7 缸燃油凸轮损坏事故</data><data key="type">事故案例</data></node><node id="ent_c75af92eb2907bf1"><data key="name">ZH 轮</data><data key="type">船舶</data></node><node id="ent_4c505785c2c9c149"><data key="name">主机 No.7 缸</data><data key="type">设备部件</data></node><node id="ent_d3b2d3b4b94f27a6"><data key="name">主机 No.8 缸</data><data key="type">设备部件</data></node><node id="ent_1efa35d68473ffad"><data key="name">凸轮轴箱</data><data key="type">设备部件</data></node><node id="ent_e0c833c17e4893b3"><data key="name">燃油凸轮</data><data key="type">设备部件</data></node><node id="ent_16d3508a9bc19389"><data key="name">主机后部有咚、咚的撞击声</data><data key="type">故障损伤</data></node><node id="ent_c03c9c8e94c948ba"><data key="name">主机异常</data><data key="type">故障损伤</data></node><node id="ent_43a29fa6a565390b"><data key="name">JH 轮主机燃油系统进入铝矿粉，造成缸套、活塞环异常磨损</data><data key="type">事故案例</data></node><node id="ent_7b44c48115feb909"><data key="name">JH 轮</data><data key="type">船舶</data></node><node id="ent_f8994718e56e2371"><data key="name">扫气箱</data><data key="type">设备部件</data></node><node id="ent_84550fb482d112e6"><data key="name">排泄管</data><data key="type">设备部件</data></node><node id="ent_cec5204994da1d7b"><data key="name">燃油供给管</data><data key="type">设备部件</data></node><node id="ent_8ca6424cf084a5b0"><data key="name">燃油沉淀柜</data><data key="type">设备部件</data></node><node id="ent_524446f54cdc56d7"><data key="name">燃油驳运系统</data><data key="type">设备部件</data></node><node id="ent_cb22a509ef17791a"><data key="name">燃油舱透气管</data><data key="type">设备部件</data></node><node id="ent_6176c50745f72e04"><data key="name">货舱顶板</data><data key="type">设备部件</data></node><node id="ent_077063e45dc79625"><data key="name">甲板</data><data key="type">设备部件</data></node><node id="ent_bc4da0f38c3b13ed"><data key="name">各缸排烟温度高</data><data key="type">故障损伤</data></node><node id="ent_d4828ddb82bc2a52"><data key="name">冒黑烟</data><data key="type">故障损伤</data></node><node id="ent_6a23c8a394910517"><data key="name">扫气箱多次着火</data><data key="type">故障损伤</data></node><node id="ent_cbe88185a1d8d7e7"><data key="name">转速大幅度波动</data><data key="type">故障损伤</data></node><node id="ent_6390fdca537fd787"><data key="name">爆燃现象</data><data key="type">故障损伤</data></node><node id="ent_8888714124dd687e"><data key="name">活塞环断裂和咬死</data><data key="type">故障损伤</data></node><node id="ent_19a7d79d26e65168"><data key="name">缸套异常磨损</data><data key="type">故障损伤</data></node><node id="ent_2ecd01e069677be7"><data key="name">扫气箱脏污严重</data><data key="type">故障损伤</data></node><node id="ent_9f4e6a19f3f8b33c"><data key="name">排泄管堵死</data><data key="type">故障损伤</data></node><node id="ent_2316bd88ff4e135b"><data key="name">燃油供给管中、分油机内沉积有大量铝矿粉</data><data key="type">故障损伤</data></node><node id="ent_3a086e5ff9fd177c"><data key="name">内部油脚很厚，均为铝矿粉</data><data key="type">故障损伤</data></node><node id="ent_2250bc4d9dbc010b"><data key="name">燃油驳运系统中也沉积了大量铝矿粉</data><data key="type">故障损伤</data></node><node id="ent_db0c0776e0bbf797"><data key="name">铝矿粉从油舱透气管上的穿孔、腐蚀破损处进入燃油舱</data><data key="type">原因因素</data></node><node id="ent_a93ffab3b9c40fc3"><data key="name">大风浪中船舶颠簸翻滚导致铝矿粉被带起</data><data key="type">原因因素</data></node><node id="ent_6992c69c75e576d9"><data key="name">返回温哥华港检查修理</data><data key="type">处置措施</data></node><node id="ent_b00b487eebc32409"><data key="name">使用轻油降速维持航行</data><data key="type">处置措施</data></node><node id="ent_0f465e21bd5db59f"><data key="name">对主机 6 只气缸进行吊缸检查</data><data key="type">处置措施</data></node><node id="ent_cb1f003f20c9ee30"><data key="name">对燃油系统进行拆检</data><data key="type">处置措施</data></node><node id="ent_c202fb797935db90"><data key="name">打开燃油沉淀柜、日用柜道门检查</data><data key="type">处置措施</data></node><node id="ent_f49d7c6badad807c"><data key="name">船上奋力抢修了一个多星期</data><data key="type">处置措施</data></node><node id="ent_833d2720bfe7d6dc"><data key="name">加装新的燃油</data><data key="type">处置措施</data></node><node id="ent_ace244ab644daa24"><data key="name">在实施机械设备检修保养时，不仅要按规定的时间间隔和检查内容进行，还必须严格按照说明书规定的检修方法和要求实施，不能用经验处理代替技术要求</data><data key="type">防范要求</data></node><node id="ent_317274c316639184"><data key="name">温哥华</data><data key="type">地点</data></node><node id="ent_e7744ab9726ed417"><data key="name">上海</data><data key="type">地点</data></node><node id="ent_ae12e4710ec012e5"><data key="name">维多利亚港</data><data key="type">地点</data></node><node id="ent_00b5eb72aadb3c14"><data key="name">GAY 轮主机透平重复发生故障和损坏</data><data key="type">事故案例</data></node><node id="ent_c183cbe517416b7a"><data key="name">GAY 轮</data><data key="type">船舶</data></node><node id="ent_b159f1f1ece03122"><data key="name">主机透平</data><data key="type">设备部件</data></node><node id="ent_afc9e2faa9a2eb34"><data key="name">扫气压力太低</data><data key="type">故障损伤</data></node><node id="ent_9cb657cd9c058402"><data key="name">排烟高温</data><data key="type">故障损伤</data></node><node id="ent_095b28a36c45562a"><data key="name">主机转速加不上去</data><data key="type">故障损伤</data></node><node id="ent_397fd086881e9224"><data key="name">严重摩擦声</data><data key="type">故障损伤</data></node><node id="ent_53d7f5ba346e0625"><data key="name">油泵断油</data><data key="type">故障损伤</data></node><node id="ent_49cf0e2641c6de2f"><data key="name">主机转速急剧下降</data><data key="type">故障损伤</data></node><node id="ent_37eda08035a6e4a5"><data key="name">油泵咬死</data><data key="type">故障损伤</data></node><node id="ent_2be0a0457add6189"><data key="name">油气封损坏</data><data key="type">故障损伤</data></node><node id="ent_16b0f7ba006ec40c"><data key="name">风机端叶轮与壳体有擦碰痕迹</data><data key="type">故障损伤</data></node><node id="ent_d64aaf7eceb4aa50"><data key="name">扫气压力只有 0.002</data><data key="type">故障损伤</data></node><node id="ent_900965857ba1acf7"><data key="name">主机无法提速</data><data key="type">故障损伤</data></node><node id="ent_270490dfcb49d420"><data key="name">两端轴承</data><data key="type">设备部件</data></node><node id="ent_31d4516b6b73a4c7"><data key="name">油泵</data><data key="type">设备部件</data></node><node id="ent_2e987c0b0dbd2b8b"><data key="name">油气封</data><data key="type">设备部件</data></node><node id="ent_dca150844d2b409e"><data key="name">风机端叶轮</data><data key="type">设备部件</data></node><node id="ent_9340a3e8473b9a79"><data key="name">壳体</data><data key="type">设备部件</data></node><node id="ent_1c2bbbaede95121b"><data key="name">透平转子</data><data key="type">设备部件</data></node><node id="ent_f09e5cc8263a20bc"><data key="name">轮机长、大管轮工作责任心差</data><data key="type">原因因素</data></node><node id="ent_0bf852ab7ad7d6e4"><data key="name">存在侥幸心理</data><data key="type">原因因素</data></node><node id="ent_038802c6c8d34fe2"><data key="name">拖延修理</data><data key="type">原因因素</data></node><node id="ent_2c8c120cb9d3a4d0"><data key="name">没有按照说明书规定和要求实施拆装</data><data key="type">原因因素</data></node><node id="ent_e8f0848d554ed550"><data key="name">内部清洁</data><data key="type">处置措施</data></node><node id="ent_af732277fd57af8e"><data key="name">更换两端轴承、油泵和油气封</data><data key="type">处置措施</data></node><node